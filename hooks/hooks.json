{
  "description": "nyolo PreToolUse safety hook — blocks dangerous operations",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "npx nyolo"
          }
        ]
      }
    ]
  }
}
